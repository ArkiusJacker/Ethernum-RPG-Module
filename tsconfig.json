{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["@league-of-foundry-developers/foundry-vtt-types"]
  },
  "include": ["scripts/**/*"],
  "exclude": ["node_modules", "dist"]
}
